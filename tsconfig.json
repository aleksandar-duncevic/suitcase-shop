{
  "compilerOptions": {
    "target": "ES6",                     
    "module": "ES6",
    "lib": ["ES2016", "DOM"],             
    "outDir": "./docs/js",                  // Compiled JS files go here
    "rootDir": "./src/ts",                  // TS source files
    "strict": true,                      
    "esModuleInterop": true,             
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,                         
    "allowJs": false,                    
  },
  "include": [
    "src/ts/main.ts"
  ],
  "exclude": [
    "node_modules",
    "docs"
  ]
}